# ============================================================
# AI Log Analyzer - Environment Configuration
# ============================================================

# ── AWS Configuration ──────────────────────────────────────
AWS_REGION=ap-southeast-1
AWS_PROFILE=default

# ── Telegram Bot Configuration (RECOMMENDED) ───────────────
# Get BOT_TOKEN from @BotFather on Telegram
# Get CHAT_ID by sending a message to your bot and checking:
# https://api.telegram.org/bot<YOUR_BOT_TOKEN>/getUpdates

TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here
TELEGRAM_ALERTS_ENABLED=true

# ── Versus Incident Service (Optional Fallback) ────────────
# Only needed if not using direct Telegram API
VERSUS_INCIDENT_URL=http://localhost:3000

# ── Application Settings ───────────────────────────────────
LOG_LEVEL=INFO
DEBUG=false

# ── Team IDS AI Configuration ──────────────────────────────
AI_PROVIDER=custom
IDS_AI_IMAGE=docker.io/nguyencntruong/ids-project:v1
IDS_AI_MODEL=ids-project:v1
CUSTOM_AI_API_URL=http://localhost:8000/analyze
CUSTOM_AI_TIMEOUT_SECONDS=120
# CUSTOM_AI_API_KEY=

# ── Streamlit Configuration ────────────────────────────────
STREAMLIT_SERVER_PORT=8501
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# ── CloudWatch Log Groups (Auto-configured) ────────────────
# These match the 9 log groups in Streamlit app:
# 1. /aws/vpc/flowlogs
# 2. /aws/cloudtrail/logs
# 3. /aws/ec2/web-tier/system
# 4. /aws/ec2/web-tier/httpd
# 5. /aws/ec2/web-tier/application
# 6. /aws/ec2/app-tier/system
# 7. /aws/ec2/app-tier/streamlit
# 8. /aws/rds/mysql/error
# 9. /aws/rds/mysql/slowquery

# ── Auto Pipeline Configuration ────────────────────────────
AUTO_ANALYSIS_ENABLED=true
AUTO_ANALYSIS_INTERVAL_MINUTES=5
AUTO_ANALYSIS_LOG_GROUPS=/aws/vpc/flowlogs,/aws/cloudtrail/logs,/aws/ec2/web-tier/system,/aws/ec2/web-tier/httpd,/aws/ec2/web-tier/application,/aws/ec2/app-tier/system,/aws/ec2/app-tier/streamlit,/aws/rds/mysql/error,/aws/rds/mysql/slowquery
AUTO_IDS_AI_MODEL=ids-project:v1
AUTO_CUSTOM_AI_API_URL=http://localhost:8000/analyze
INCIDENT_DATA_DIR=/data/incidents
INCIDENT_RETENTION_DAYS=7
