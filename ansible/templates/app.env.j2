# AWS Configuration
AWS_REGION={{ aws_region | default('ap-southeast-1') }}

# Bedrock Configuration
BEDROCK_MODEL={{ bedrock_model | default('us.amazon.nova-micro-v1:0') }}
MAX_TOKENS={{ max_tokens | default(2000) }}
TEMPERATURE={{ temperature | default(0.3) }}

# Streamlit Configuration
STREAMLIT_SERVER_PORT={{ app_port }}
STREAMLIT_SERVER_ADDRESS=0.0.0.0

# Telegram Alert Configuration
TELEGRAM_ALERTS_ENABLED={{ telegram_alerts_enabled | default('true') }}
TELEGRAM_BOT_TOKEN={{ telegram_bot_token }}
TELEGRAM_CHAT_ID={{ telegram_chat_id }}

# Auto Pipeline Configuration
AUTO_ANALYSIS_ENABLED={{ auto_analysis_enabled | default('true') }}
AUTO_ANALYSIS_INTERVAL_MINUTES={{ auto_analysis_interval | default(5) }}
AUTO_ANALYSIS_LOG_GROUPS={{ auto_analysis_log_groups | default('/aws/vpc/flowlogs,/aws/cloudtrail/logs,/aws/ec2/web-tier/system,/aws/ec2/web-tier/httpd,/aws/ec2/web-tier/application,/aws/ec2/app-tier/system,/aws/ec2/app-tier/streamlit,/aws/rds/mysql/error,/aws/rds/mysql/slowquery') }}
AUTO_BEDROCK_MODEL={{ auto_bedrock_model | default('anthropic.claude-3-haiku-20240307-v1:0') }}
INCIDENT_DATA_DIR={{ incident_data_dir | default('/data/incidents') }}
INCIDENT_RETENTION_DAYS={{ incident_retention_days | default(7) }}
